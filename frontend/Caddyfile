# The backend routes live at the root (/expenses, /forecast, /chat, /health),
# so we strip the /api prefix before proxying: /api/expenses -> /expenses.
# Plain HTTP on :80 inside the container, mapped to host :8080.
:80 {
	encode gzip

	handle_path /api/* {
		reverse_proxy api:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
