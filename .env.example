# -- Application ---------------------------------------------------- #
APP_NAME="Expense Forecasting API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# -- Database -------------------------------------------------------- #
# SQLite (default MVP - zero setup)
DATABASE_URL=sqlite:///./data/expenses.db

# PostgreSQL (swap when ready)
# DATABASE_URL=postgresql+psycopg://expense:expense@localhost:5432/expense_db

# -- LLM Provider --------------------------------------------------- #
# "anthropic" or "openai"
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2048
LLM_BATCH_SIZE=20

# -- ML -------------------------------------------------------------- #
MODEL_PATH=./data/models
MIN_MONTHS_FOR_FORECAST=2

# -- Conversational agent ("Chat with your finances") --------------- #
# Provider-agnostic. Three ways to run it:
#
#  (a) Local LM Studio (OpenAI-compatible, no cloud key) -- the default:
CHAT_LLM_PROVIDER=openai
CHAT_LLM_MODEL=google/gemma-4-12b-qat
LLM_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=lm-studio
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_BASE_URL=http://localhost:1234/v1
#
#  (b) Cloud OpenAI: set OPENAI_API_KEY to a real key and clear LLM_BASE_URL.
#  (c) Cloud Anthropic: CHAT_LLM_PROVIDER=anthropic, CHAT_LLM_MODEL=claude-haiku-4-5-20251001,
#      set ANTHROPIC_API_KEY, clear LLM_BASE_URL.
#  (d) Cloud Gemini: CHAT_LLM_PROVIDER=gemini, set GEMINI_API_KEY
#      (also: pip install langchain-google-genai).

CHAT_LLM_TEMPERATURE=0.0
CHAT_MAX_TOKENS=512
CHAT_RETRIEVAL_K=4
CHAT_MAX_REWRITES=1

# -- LangSmith tracing (optional) ----------------------------------- #
# Enable by running the API with: uvicorn app.main:app --env-file .env
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_key
# LANGSMITH_PROJECT="Expense Chat"
